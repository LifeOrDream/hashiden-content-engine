# Hashiden AI Content Engine local configuration
#
# Copy this to `.env` for local generation. Real `.env` files are ignored by git.

# Generation providers
FAL_API_KEY=your_fal_key_here
FAL_IMAGE_MODEL=fal-ai/nano-banana-2/edit
MUTATION_VIDEO_FAL_MODEL=bytedance/seedance-2.0/image-to-video
FAL_VOICE_DESIGN_MODEL=fal-ai/minimax/voice-design
FAL_TTS_MODEL=fal-ai/minimax/speech-02-hd
FAL_MUSIC_MODEL=fal-ai/stable-audio
FAL_SFX_MODEL=fal-ai/stable-audio
FAL_LIPSYNC_MODEL=fal-ai/sync-lipsync/v2

# Optional LLM provider for trailer script passes
TRAILER_LLM_PROVIDER=fal
TRAILER_LLM_MODEL=anthropic/claude-sonnet-4.6
TRAILER_LLM_MAX_TOKENS=32000
CONTENT_ENGINE_LLM_PROVIDER=fal
CONTENT_ENGINE_LLM_MODEL=anthropic/claude-sonnet-4.6
CONTENT_ENGINE_LLM_MAX_TOKENS=32000
GEMINI_KEY=your_gemini_key_here

# world.brief job — grounded Gemini + google-search per-country parody briefs
# (soft-fails to empty briefs without GEMINI_KEY; backend schedules + persists)
# WORLD_BRIEF_LLM_MODEL=gemini-2.5-flash
# WORLD_BRIEF_LOOKBACK_DAYS=14

# Chapter -> video producer + replay (scripts/produce_chapter.ts, scripts/replay_chapter.ts, /chapters WebUI)
# Set DISABLE_LLM=true to freeze the deterministic text spine for byte-reproducible replays.
# chapter.produce jobs with budgetUsd derive duration/resolution from the
# episode budget tier table (episodeTierForBudget in src/service/chapterVideo.ts)
# and, when the artifact store is s3, upload final.mp4 + cover.png under
# chapters/<warId>/ and return hosted URLs. These envs stay the no-budget defaults.
CHAPTER_WRITER_DISABLE_LLM=false
CHAPTER_TARGET_SECONDS=75
CHAPTER_MIN_SECONDS=24
CHAPTER_COUNTDOWN=04:00:00
# CHAPTER_CTA=Mine your HashBeast — hashiden.tv

# Service mode: backend enqueues work here, content engine consumes it.
CONTENT_ENGINE_QUEUE=hashiden-content-engine
CONTENT_ENGINE_WORKER_CONCURRENCY=2
VALKEY_HOST=localhost
VALKEY_PORT=6379
# VALKEY_SENTINEL_HOSTS=10.0.1.11:26379,10.0.1.12:26379,10.0.1.51:26379
# VALKEY_MASTER_NAME=hashiden-master
# REDIS_TLS=false

# S3 upload target for generated frames/clips
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
# TODO(rebrand-infra): live S3 bucket + CDN host not yet migrated off the legacy
# name. Point these at hashiden-assets-prod / assets.hashiden.tv once the bucket
# and CDN are cut over (see operator checklist).
BUCKET_NAME=minebtc-assets-prod
HASHBEAST_ASSETS_BASE_URL=https://assets.minebtc.fun/hashbeast-assets

# NFT asset pipeline (nft.* jobs — see docs/nft-pipeline.md)
# Artifact persistence port: "s3" uploads + returns URLs, "inline" returns
# base64 in the job result. Auto: s3 when a bucket is configured, else inline.
NFT_ARTIFACT_STORE=inline
# Mint art model (collectible-grade sprites; mutation strips use FAL_IMAGE_MODEL)
NFT_MINT_IMAGE_MODEL=fal-ai/nano-banana-pro/edit
NFT_MINT_MAX_RETRIES=3
# Gemini vision model for mint/animation identity validation
NFT_VALIDATE_MODEL=gemini-2.5-flash
# Breed base-body reference sprites (style anchors for mint generation).
# Either a local directory of <breed>.png files or a CDN base URL — or pass
# referenceImageUrl per job and leave both unset.
HASHBEAST_BASE_BODIES_DIR=
HASHBEAST_BASE_BODIES_BASE_URL=
# Base types renderable on this deployment (docs/base-types.md). Genesis is
# canine; primate/amphibian/feline are lootbox/rebirth forms — restrict to
# "canine" until that path ships.
HASHBEAST_BASE_TYPE_ALLOWLIST=canine,primate,amphibian,feline
# Chroma-strip animation assembly (python3 + Pillow + numpy + scipy required)
HASHBEAST_ANIM_CHROMA=0xFF00FF
HASHBEAST_ANIM_FRAMES=5
HASHBEAST_ANIM_FRAME_MS=160
HASHBEAST_ANIM_TARGET=512
# HASHBEAST_ANIM_PYTHON=python3
# HASHBEAST_ANIM_ASSEMBLER=/abs/path/to/assemble_anim.py
# Shared HashBeast voices (faction x breed x stage band)
HASHBEAST_VOICE_STAGE_BANDS=0-3,4-7
# Cycle summary stitch (ffmpeg required)
NFT_CYCLE_SUMMARY_FPS=15
NFT_CYCLE_SUMMARY_SIZE=720
NFT_CYCLE_SUMMARY_BG=0x0d0f1a

# Trailer render controls
TRAILER_VIDEO_RES=1080p
TRAILER_IMAGE_RES=2K
TRAILER_LIPSYNC=true
TRAILER_APPROVE_PER_SCENE=false
TRAILER_MUSIC_URL=

# Optional Telegram delivery
TELEGRAM_NFTS_BOT=your_bot_token_here
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Branding / CTA
VIDEO_BRAND_ENABLED=true
VIDEO_BRAND_WIDTH_PCT=0.4
VIDEO_BRAND_TOP_PCT=0.05
CONTENT_ENDCARD_SECONDS=3.5
CONTENT_ENDCARD_CTA1=MINE YOUR HASHBEAST
CONTENT_ENDCARD_CTA2=hashiden.tv
CONTENT_ENDCARD_CTA3=SUBSCRIBE + FOLLOW
