# Hashiden pet content worker

# BullMQ / Valkey
CONTENT_ENGINE_QUEUE=hashiden-content-engine
CONTENT_ENGINE_WORKER_CONCURRENCY=2
VALKEY_HOST=localhost
VALKEY_PORT=6379
# VALKEY_SENTINEL_HOSTS=10.0.1.11:26379,10.0.1.12:26379
# VALKEY_MASTER_NAME=hashiden-master
# VALKEY_PASSWORD=
# REDIS_TLS=false

# Image generation
FAL_KEY=your_fal_key_here
PET_IMAGE_GENERATION_MODEL=fal-ai/nano-banana-2
PET_IMAGE_EDIT_MODEL=fal-ai/nano-banana-2/edit
PET_IMAGE_TIMEOUT_MS=180000
FAL_POLL_INTERVAL_MS=3000

# Artifact storage. Production should use s3 because the backend persists URLs.
PET_ARTIFACT_STORE=s3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
BUCKET_NAME=hashiden-assets-prod
PET_ASSET_ROOT=hashbeast-assets
# NOTE: still the legacy MineBTC-era domain; keep until infra cuts over to a Hashiden domain.
HASHBEAST_ASSETS_BASE_URL=https://assets.minebtc.fun/hashbeast-assets

# Localnet alternative: preserve production keys under the frontend public tree.
# PET_ARTIFACT_STORE=local
# PET_LOCAL_ASSET_DIR=/absolute/path/to/hashiden-game/public/assets/generated/hashbeast-assets
# PET_LOCAL_ASSET_BASE_URL=http://localhost:3100/assets/generated/hashbeast-assets
