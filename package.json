{
  "name": "hashiden-content-engine",
  "version": "0.1.0",
  "description": "Portable pet-art worker for Hashiden mint, expression, evolution, and rare-card media.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": "./dist/src/index.js",
    "./pet-content": "./dist/src/pet-content/index.js"
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "prebuild": "npm run clean",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test:contract": "tsx scripts/petContract.test.ts",
    "test:prompts": "tsx scripts/petPrompts.test.ts",
    "test:generator": "tsx scripts/petGenerator.test.ts",
    "test:artifacts": "tsx scripts/artifacts.test.ts",
    "test:assets": "tsx scripts/baseBodies.test.ts",
    "test": "npm run typecheck && npm run test:contract && npm run test:prompts && npm run test:generator && npm run test:artifacts && npm run test:assets",
    "check:oss": "npm test",
    "service:worker": "tsx src/service/worker.ts",
    "service:worker:built": "node dist/src/service/worker.js"
  },
  "keywords": [
    "hashiden",
    "hashbeasts",
    "ai-content",
    "virtual-pets",
    "game-art"
  ],
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@google/genai": "^2.11.0",
    "bullmq": "^5.79.2",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.20.5",
    "typescript": "^6.0.3"
  }
}
